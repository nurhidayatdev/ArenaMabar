rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'updatedAt'])
        && data.displayName is string
        && data.displayName.size() <= 100
        && (data.keys().hasAny(['favoriteSport']) == false || (data.favoriteSport is string && data.favoriteSport.size() <= 50))
        && (data.keys().hasAny(['favoriteSports']) == false || (data.favoriteSports is list && data.favoriteSports.size() <= 100))
        && (data.keys().hasAny(['bio']) == false || (data.bio is string && data.bio.size() <= 500))
        && data.updatedAt == request.time;
    }

    match /users/{userId} {
      // Any authenticated user can read profiles (or restricted if PII, but we consider this public profile)
      allow read: if isSignedIn();
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'favoriteSport', 'favoriteSports', 'bio', 'updatedAt'])
      );

      match /favorites_radar/{favId} {
        allow read, write: if isOwner(userId);
      }

      match /favorites_shopper/{favId} {
        allow read, write: if isOwner(userId);
      }

      match /history_kalkulator/{histId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
